{
  "name": "aptech-uyo-code-submission",
  "version": "0.0.1",
  "description": "Simple pages to handle code execution and submission, to host programming tests",
  "author": "Solution Tech Limited",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build && babel public --out-dir public --only **/custom.js --out-file-extension .min.js",
    "db": "typeorm-ts-node-commonjs -d src/orm.config.ts",
    "db:prod": "typeorm -d dist/orm.config.js",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "reactivate": "nest start --entryFile reactivate",
    "repl": "nest start --entryFile repl",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" && tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/typeorm": "^10.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "csrf-sync": "^4.2.0",
    "express-session": "^1.18.1",
    "hbs": "^4.2.0",
    "hbs-utils": "^0.0.4",
    "helmet": "^8.0.0",
    "mime-types": "^2.1.35",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "session-file-store": "^1.5.0",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@babel/cli": "^7.26.4",
    "@babel/core": "^7.26.7",
    "@babel/preset-env": "^7.26.7",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.17",
    "@types/express-session": "^1.18.0",
    "@types/hbs": "^4.0.4",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/session-file-store": "^1.2.5",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "babel-preset-minify": "^0.5.2",
    "dotenv": "^16.4.5",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "jest-extended": "^4.0.2",
    "prettier": "^3.0.0",
    "prettier-plugin-organize-imports": "^4.1.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "engines": {
    "npm": ">=10.0.0",
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aptech-uyo/code-submission.git"
  },
  "bugs": {
    "url": "https://github.com/aptech-uyo/code-submission/issues"
  },
  "homepage": "https://github.com/aptech-uyo/code-submission",
  "cspell": {
    "version": "0.2",
    "words": [
      "typeorm",
      "aptech"
    ]
  }
}
