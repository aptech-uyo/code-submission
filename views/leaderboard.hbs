{{#>base}}
{{#*inline 'content'}}

<h1 style="font-size:1.8rem; font-weight:800; margin-bottom:0.25rem;">🏆 Leaderboard</h1>
<p style="color:var(--text-muted); margin-bottom:2rem;">Live standings — refreshes automatically every 30 seconds.</p>

<div id="board"></div>

<script>
  const rows = {{{rows}}};

  function render(data) {
    if (!data.length) {
      document.getElementById('board').innerHTML = '<div class="card" style="text-align:center;color:var(--text-muted);">No submissions yet.</div>';
      return;
    }
    let html = '<table><thead><tr><th>#</th><th>Name</th><th>Q1</th><th>Q2</th><th>Score</th></tr></thead><tbody>';
    data.forEach((row, i) => {
      const q1 = row.questions[1] || '—';
      const q2 = row.questions[2] || '—';
      const badge = (v) => {
        if (v === 'ACCEPTED') return '<span class="badge badge-success">AC</span>';
        if (v === 'ATTEMPTED') return '<span class="badge badge-warn">ATT</span>';
        return '<span style="color:var(--text-muted);">—</span>';
      };
      const medal = i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : `${i+1}.`;
      html += `<tr>
        <td style="font-weight:700;">${medal}</td>
        <td style="font-weight:600;">${row.name}</td>
        <td>${badge(q1)}</td>
        <td>${badge(q2)}</td>
        <td><strong style="color:#4caf50;">${row.totalPassed}</strong></td>
      </tr>`;
    });
    html += '</tbody></table>';
    document.getElementById('board').innerHTML = html;
  }

  render(rows);

  // Auto-refresh page every 30 seconds so leaderboard stays current
  setTimeout(() => location.reload(), 30000);
</script>

{{/inline}}
{{/base}}