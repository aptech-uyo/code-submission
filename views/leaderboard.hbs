{{#>base}}
{{#*inline 'content'}}

<h1 style="font-size:1.8rem; font-weight:800; margin-bottom:0.25rem;">Leaderboard</h1>
<p style="color:var(--text-muted); margin-bottom:2rem;">Live standings — refreshes automatically every 30 seconds.</p>

<div id="board"></div>

<script>
  const rows = {{{rows}}};
  const Q1_ID = 1;
  const Q2_ID = 2;

  function render(data) {
    if (!data.length) {
      document.getElementById('board').innerHTML = '<div class="card" style="text-align:center;color:var(--text-muted);">No submissions yet.</div>';
      return;
    }
    let html = '<table><thead><tr><th>#</th><th>Name</th><th>Q1</th><th>Q2</th></tr></thead><tbody>';
    data.forEach((row, i) => {
      const now = new Date()

      const best = (subs) => {
        const accepted = subs.filter(sub => sub.status === 'ACCEPTED').reduce((prev, i) => {
          const prevTime = prev ? new Date(prev.createdAt).getTime() : null;
          const iTime = new Date(i.createdAt).getTime();
          return prev ? (prevTime < iTime ? prev : i) : i
        }, null);
        if (accepted) {
          const diffMs = new Date(accepted.createdAt) - new Date('{{competitionStartTime}}');
          const diffMins = Math.floor(((diffMs % 86400000) % 3600000) / 60000);
          const diffSecs = Math.round(((diffMs % 86400000) % 3600000) / 600000);
          return `<span style="color:var(--success);">+ ${diffMins}:${`${diffSecs}`.padStart(2, '0')}</span>`;
        }

        const rejected = subs.reduce((prev, i) => {
          const prevTime = prev ? new Date(prev.createdAt).getTime() : null;
          const iTime = new Date(i.createdAt).getTime();
          return prev ? (prevTime < iTime ? prev : i) : i
        }, null);
        if (rejected) {
          const diffMs = new Date(rejected.createdAt) - new Date('{{competitionStartTime}}');
          const diffMins = Math.floor(((diffMs % 86400000) % 3600000) / 60000);
          const diffSecs = Math.round(((diffMs % 86400000) % 3600000) / 60000000);
          return `<span style="color:var(--error);">+ ${diffMins}:${`${diffSecs}`.padStart(2, '0')}</span>`;
        }

        return '';
      };

      const medal = `${i+1}.`;
      html += `<tr>
        <td style="font-weight:700;">${medal}</td>
        <td style="font-weight:600;">${row.studentName}</td>
        <td>${best(row.submissions.filter(sub => sub.questionId == Q1_ID))}</td>
        <td>${best(row.submissions.filter(sub => sub.questionId == Q2_ID))}</td>
      </tr>`;
    });
    html += '</tbody></table>';
    document.getElementById('board').innerHTML = html;
  }

  render(rows);

  // Auto-refresh page every 30 seconds so leaderboard stays current
  setTimeout(() => location.reload(), 30000);
</script>

{{/inline}}
{{/base}}
