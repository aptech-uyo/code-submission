<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ pageTitle }} | Programming Competition</title>
  <link rel="shortcut icon" href="/assets/favicon.ico" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #1a1a2e;
      --surface: #16213e;
      --card: #0f3460;
      --accent: #e94560;
      --accent2: #0f9b8e;
      --text: #e0e0e0;
      --text-muted: #9e9e9e;
      --border: #2a2a4e;
      --success: #4caf50;
      --error: #f44336;
      --warn: #ff9800;
      --info: #2196f3;
      --code-bg: #0d1117;
    }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Segoe UI', system-ui, sans-serif;
      min-height: 100vh;
    }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    .navbar {
      background: var(--surface);
      border-bottom: 2px solid var(--accent);
      padding: 0 2rem;
      display: flex;
      align-items: center;
      gap: 2rem;
      height: 56px;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .navbar .brand {
      font-weight: 700;
      font-size: 1.2rem;
      color: var(--accent);
      letter-spacing: 1px;
    }
    .navbar a {
      color: var(--text);
      font-size: 0.95rem;
      padding: 0.25rem 0.5rem;
      border-radius: 4px;
      transition: background 0.2s;
    }
    .navbar a:hover { background: var(--border); text-decoration: none; }
    .container { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem; }
    .btn {
      display: inline-block;
      padding: 0.5rem 1.25rem;
      border-radius: 6px;
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      border: none;
      transition: opacity 0.2s, transform 0.1s;
    }
    .btn:hover { opacity: 0.85; transform: translateY(-1px); }
    .btn:active { transform: translateY(0); }
    .btn-primary { background: var(--accent); color: #fff; }
    .btn-secondary { background: var(--accent2); color: #fff; }
    .btn-outline { background: transparent; border: 1.5px solid var(--accent); color: var(--accent); }
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.5rem;
    }
    .badge {
      display: inline-block;
      padding: 2px 10px;
      border-radius: 12px;
      font-size: 0.78rem;
      font-weight: 600;
    }
    .badge-success { background: #1b5e20; color: #a5d6a7; }
    .badge-error { background: #b71c1c; color: #ffcdd2; }
    .badge-warn { background: #e65100; color: #ffe0b2; }
    .badge-info { background: #0d47a1; color: #bbdefb; }
    pre, code { font-family: 'Cascadia Code', 'Fira Code', 'Consolas', monospace; }
    pre {
      background: var(--code-bg);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 1rem;
      overflow-x: auto;
      font-size: 0.9rem;
      line-height: 1.6;
    }
    table { border-collapse: collapse; width: 100%; }
    th, td { border: 1px solid var(--border); padding: 0.6rem 1rem; text-align: left; }
    th { background: var(--card); font-weight: 600; }
    tr:nth-child(even) { background: rgba(255,255,255,0.03); }
    .timer-bar {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 0.4rem 2rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      font-size: 0.9rem;
    }
    #competition-timer {
      font-weight: 700;
      font-size: 1rem;
      color: var(--accent2);
      letter-spacing: 1px;
      min-width: 80px;
    }
    #competition-timer.warn { color: var(--warn); }
    #competition-timer.danger { color: var(--error); animation: pulse 1s infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.5} }
    .progress-bar-wrap { flex:1; background: var(--border); border-radius:4px; height:6px; }
    .progress-bar-fill { height:6px; border-radius:4px; background: var(--accent2); transition: width 1s linear; }
  </style>
  {{#>optionalStylesheets}}{{/optionalStylesheets}}
</head>
<body>
  <nav class="navbar">
    <span class="brand">⚡ CodeComp</span>
    <a href="/">Instructions</a>
    <a href="/questions">Problems</a>
    <a href="/leaderboard">Leaderboard</a>
  </nav>
  <div class="timer-bar">
    <span>⏱ Time remaining:</span>
    <span id="competition-timer">1:15:00</span>
    <div class="progress-bar-wrap">
      <div class="progress-bar-fill" id="timer-fill" style="width:100%"></div>
    </div>
  </div>
  <div class="container">
    {{>content}}
  </div>
  <script>
    // Competition timer — 1 hour 15 minutes
    const TOTAL = 75 * 60;
    const KEY = 'comp_start';
    let start = parseInt(localStorage.getItem(KEY) || '0');
    if (!start) { start = Date.now(); localStorage.setItem(KEY, start); }
    const el = document.getElementById('competition-timer');
    const fill = document.getElementById('timer-fill');
    function tick() {
      const elapsed = Math.floor((Date.now() - start) / 1000);
      const remaining = Math.max(0, TOTAL - elapsed);
      const h = Math.floor(remaining / 3600);
      const m = Math.floor((remaining % 3600) / 60);
      const s = remaining % 60;
      const label = h > 0
        ? `${h}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`
        : `${m}:${String(s).padStart(2,'0')}`;
      el.textContent = label;
      el.className = remaining < 300 ? 'danger' : remaining < 900 ? 'warn' : '';
      fill.style.width = ((remaining / TOTAL) * 100) + '%';
      fill.style.background = remaining < 300 ? '#f44336' : remaining < 900 ? '#ff9800' : '#0f9b8e';
      if (remaining === 0) {
        el.textContent = 'TIME UP';
        document.body.insertAdjacentHTML('afterbegin',
          '<div style="position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:9999;display:flex;align-items:center;justify-content:center;font-size:3rem;font-weight:900;color:#e94560;">⏰ TIME IS UP!</div>');
        clearInterval(interval);
      }
    }
    tick();
    const interval = setInterval(tick, 1000);
  </script>
</body>
</html>